# Cloudflare Pages headers
# Long-lived cache for images — they're content-addressed by filename
# changes (book{N}_v8_cover.png etc.); a redeploy refreshes the path.

/img/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=604800

# Slightly looser cache for HTML so content updates land within a day.
/*
  Cache-Control: public, max-age=3600, must-revalidate
