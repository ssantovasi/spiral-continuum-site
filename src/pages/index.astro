---
import Layout from '../layouts/Layout.astro';
import author from '../content/site/author.json';
---

<Layout title="Steven Saint" description={author.bio_short}>
  <section class="hero">
    <p class="author-sub">{author.tagline}</p>
    <h1>Steven Saint</h1>
    <p class="author-tag">{author.bio_short}</p>
  </section>

  <hr class="ornament" />

  {author.series.map((s) => (
    <a class="series-card" href={s.url}>
      <div class="label">{s.id === 'spiral-continuum' ? 'Series I' : 'Series II'}</div>
      <h2>{s.title}</h2>
      <div class="status">{s.volumes} volumes · {s.status_detail}</div>
      <div class="tag">{s.tagline}</div>
      <div class="cta">Read the series &rarr;</div>
    </a>
  ))}

  <hr class="ornament" />

  <p class="muted" style="text-align: center;">
    <a href="/author">More about Steven Saint</a>
    &nbsp;&middot;&nbsp;
    <a href="/maps">Series maps</a>
  </p>
</Layout>
