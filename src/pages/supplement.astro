---
import Layout from '../layouts/Layout.astro';
import supplement from '../content/site/supplement.json';
---

<Layout title="Maps & Timeline" description={supplement.description}>
  <h1>{supplement.title}</h1>
  <p class="tagline">{supplement.description}</p>

  <p>
    <a class="buy-link" href={supplement.download_url}>Download the PDF ({supplement.current_version})</a>
  </p>

  <hr class="ornament" />

  <h2>Why a separate supplement?</h2>
  <p>{supplement.why_separate}</p>

  <hr class="ornament" />

  <h2>Contents</h2>
  {supplement.contents.map((section) => (
    <>
      <h3>{section.page_group}</h3>
      <ul>
        {section.items.map((item) => <li>{item}</li>)}
      </ul>
    </>
  ))}

  <p class="muted">
    Released {supplement.current_release_date}. Source repo:
    {' '}<a href={supplement.repo_url}>{supplement.repo_url}</a>.
  </p>
</Layout>
