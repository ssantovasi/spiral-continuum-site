---
import Layout from '../layouts/Layout.astro';
import spiralTimeline from '../content/site/timeline.json';
import iobTimeline from '../content/iob-site/timeline.json';
import { getCollection } from 'astro:content';

const spiralDeepDives = await getCollection('timeline');
const iobDeepDives    = await getCollection('iobTimeline');

const spiralSlugs = new Set(spiralDeepDives.map((d) => d.data.slug));
const iobSlugs    = new Set(iobDeepDives.map((d) => d.data.slug));

type Entry = (typeof spiralTimeline)['entries'][number];

function bySeries(data: typeof spiralTimeline, deepDiveSlugs: Set<string>) {
  const entries = [...data.entries].sort((a, b) => a.year - b.year);
  const groupedByEra: Record<string, Entry[]> = {};
  for (const era of data.eras) {
    groupedByEra[era.id] = entries.filter((e) => e.era === era.id);
  }
  return { entries, groupedByEra };
}

const spiral = bySeries(spiralTimeline, spiralSlugs);
const iob    = bySeries(iobTimeline as any, iobSlugs);
---

<Layout title="The Master Timelines" description="Chronological canon for both Steven Saint series.">
  <header class="tl-header">
    <h1>The Master Timelines</h1>
    <p class="tagline">
      From the asker's hill at Almada to the Lapa kitchen-table closing
      day; from the pale man's drift south to the Codec's keyed
      resurfacing. Two series, two chronologies, one careful audience.
    </p>
  </header>

  <nav class="series-tabs" aria-label="Choose a series">
    <a href="#spiral-continuum" class="series-tab">
      <span class="label">The Spiral Continuum</span>
      <span class="status">{spiralTimeline.entries.length} entries · {spiralDeepDives.length} deep-dives</span>
    </a>
    <a href="#island-of-bones" class="series-tab">
      <span class="label">Island of Bones</span>
      <span class="status">{iobTimeline.entries.length} entries · {iobDeepDives.length} deep-dives</span>
    </a>
  </nav>

  <hr class="ornament" />

  <section id="spiral-continuum" class="tl-series">
    <header class="tl-series-head">
      <h2><span class="glyph">☰</span> The Spiral Continuum</h2>
      <p class="muted">{spiralTimeline.subtitle}</p>
    </header>

    <nav class="tl-eras" aria-label="Jump to Spiral era">
      {spiralTimeline.eras.map((era) => (
        <a href={`#spiral-era-${era.id}`} class="tl-era-link">
          <span class="glyph">{era.glyph}</span>
          <span class="label">{era.label}</span>
          <span class="range">{era.range}</span>
        </a>
      ))}
    </nav>

    {spiralTimeline.eras.map((era) => (
      <section class="tl-era" id={`spiral-era-${era.id}`}>
        <header class="tl-era-header">
          <span class="glyph">{era.glyph}</span>
          <h3>{era.label}</h3>
          <span class="range">{era.range}</span>
        </header>

        <ol class="tl-entries">
          {spiral.groupedByEra[era.id].map((entry) => {
            const hasDeepDive = entry.slug && spiralSlugs.has(entry.slug);
            return (
              <li class={`tl-entry${hasDeepDive ? ' has-deep-dive' : ''}`}>
                <time class="tl-date">{entry.date}</time>
                <div class="tl-body">
                  <h4 class="tl-title">{entry.title}</h4>
                  <p class="tl-summary">{entry.summary}</p>
                  {entry.quote && (<blockquote class="tl-quote">{entry.quote}</blockquote>)}
                  <div class="tl-meta">
                    {entry.books.length > 0 && <span class="tl-books">{entry.books.join(' · ')}</span>}
                    {hasDeepDive && <a class="tl-link" href={`/timeline/${entry.slug}`}>Read more &rarr;</a>}
                  </div>
                </div>
              </li>
            );
          })}
        </ol>
      </section>
    ))}
  </section>

  <hr class="ornament" />

  <section id="island-of-bones" class="tl-series">
    <header class="tl-series-head">
      <h2><span class="glyph">⌒</span> Island of Bones</h2>
      <p class="muted">{iobTimeline.subtitle}</p>
    </header>

    <nav class="tl-eras" aria-label="Jump to IoB era">
      {iobTimeline.eras.map((era) => (
        <a href={`#iob-era-${era.id}`} class="tl-era-link">
          <span class="glyph">{era.glyph}</span>
          <span class="label">{era.label}</span>
          <span class="range">{era.range}</span>
        </a>
      ))}
    </nav>

    {iobTimeline.eras.map((era) => (
      <section class="tl-era" id={`iob-era-${era.id}`}>
        <header class="tl-era-header">
          <span class="glyph">{era.glyph}</span>
          <h3>{era.label}</h3>
          <span class="range">{era.range}</span>
        </header>

        <ol class="tl-entries">
          {iob.groupedByEra[era.id].map((entry) => {
            const hasDeepDive = entry.slug && iobSlugs.has(entry.slug);
            return (
              <li class={`tl-entry${hasDeepDive ? ' has-deep-dive' : ''}`}>
                <time class="tl-date">{entry.date}</time>
                <div class="tl-body">
                  <h4 class="tl-title">{entry.title}</h4>
                  <p class="tl-summary">{entry.summary}</p>
                  {entry.quote && (<blockquote class="tl-quote">{entry.quote}</blockquote>)}
                  <div class="tl-meta">
                    {entry.books.length > 0 && <span class="tl-books">{entry.books.join(' · ')}</span>}
                    {hasDeepDive && <a class="tl-link" href={`/timeline/${entry.slug}`}>Read more &rarr;</a>}
                  </div>
                </div>
              </li>
            );
          })}
        </ol>
      </section>
    ))}
  </section>

  <hr class="ornament" />

  <p class="muted">
    Sourced from <code>.analysis/series_timeline.md</code> (Spiral
    Continuum, 698 lines) and <code>docs/05_timeline.md</code> (Island
    of Bones). Selected landmark entries have dedicated deep-dive pages
    — follow the <em>Read more</em> links above.
  </p>
</Layout>
