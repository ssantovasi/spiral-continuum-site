---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import series from '../../content/iob-site/series.json';

const books = (await getCollection('iobBooks')).sort(
  (a, b) => a.data.reading_order - b.data.reading_order
);
---

<Layout title={series.title} description={series.elevator_pitch}>
  <h1>{series.title}</h1>
  <p class="tagline">{series.elevator_pitch}</p>

  <hr class="ornament" />

  <h2>The Nine Volumes</h2>
  <p class="muted">
    {series.structure}
  </p>
  <p class="muted">
    <strong style="color: var(--gold);">Status:</strong> {series.status_detail}
  </p>

  <div class="book-grid">
    {books.map((book) => {
      const hasFront = book.data.art.front !== null;
      const isWorking = book.data.title_status === 'working';
      return (
        <a class={`book-card${hasFront ? '' : ' placeholder'}`} href={`/island-of-bones/books/${book.data.id}`}>
          <div class="cover-frame">
            {hasFront && (
              <img src={`/img/${book.data.art.front}`} alt={book.data.title} loading="lazy" />
            )}
          </div>
          <div class="vol">{book.data.volume_label}</div>
          <div class="title">
            {book.data.title}
            {isWorking && <span style="font-size: 0.78em; color: var(--color-text-dim); font-style: italic;"> (working title)</span>}
          </div>
          <div class="tag">{book.data.tagline}</div>
          <div class="status-pill">{book.data.status}</div>
        </a>
      );
    })}
  </div>

  <hr class="ornament" />

  <h2>About the series</h2>
  <p>{series.voice}</p>
  <p>
    <strong style="color: var(--gold);">Register.</strong> {series.register}
  </p>

  <h3>Hero settings</h3>
  <ul>
    {series.settings_hero.map((s) => <li>{s}</li>)}
  </ul>
</Layout>
