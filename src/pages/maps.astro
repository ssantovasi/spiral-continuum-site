---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import supplement from '../content/site/supplement.json';

const books = (await getCollection('books')).sort(
  (a, b) => a.data.reading_order - b.data.reading_order
);

const mapCaptions: Record<number, string> = {
  1: 'Lisbon · the Atlantic · the upper Rio Negro. September–November 2026.',
  2: 'The four-continent expedition — seven knot-sites, four clinics. April–May 2026.',
  3: 'Cabeceiras de Basto · the Andean approach. October–December 2026.',
  4: "Almeida's life across four panels — Bahia · Rio Negro · Lisbon &amp; Rome · Coimbra &amp; Setúbal. 1566–1653.",
  5: 'Cabeceiras de Basto · the 1948 voyage to Buriti. 1892–1967.',
  6: 'Cabeceiras de Basto · Coimbra · Lisbon · Setúbal. Ninety years of silence, 1755–1849.',
  7: 'Lisbon · Geneva · Madrid · Reykjavik. The modern operational close, 2028–2029.',
  8: 'Estrela · Geneva · Iberia. The 2018–2027 relays.',
};
---

<Layout title="Maps" description="Photo-realistic map artifacts for both Steven Saint series.">
  <h1>Maps</h1>
  <p class="tagline">
    Photo-realistic museum-artifact renderings — the maps you'd find on a
    Lapa desk, a Coimbra refectory table, a captain's situation wall.
  </p>

  <nav class="series-tabs" aria-label="Choose a series">
    <a href="#spiral-continuum" class="series-tab">
      <span class="label">The Spiral Continuum</span>
      <span class="status">8 maps · overall · timeline</span>
    </a>
    <a href="#island-of-bones" class="series-tab">
      <span class="label">Island of Bones</span>
      <span class="status">Supplement in progress</span>
    </a>
  </nav>

  <hr class="ornament" />

  <section id="spiral-continuum" class="maps-section">
    <header class="maps-section-head">
      <h2><span class="glyph">☰</span> The Spiral Continuum</h2>
      <p class="muted">
        Nine parchment-stylized canonical maps with full place-name detail
        ship inside the free <a href={supplement.download_url}>supplement
        PDF ({supplement.current_version})</a>. The artifact renderings on
        this page are mood-pieces; the PDF is the source.
      </p>
      <p>
        <a class="buy-link" href={supplement.download_url}>Download supplement PDF</a>
      </p>
    </header>

  <h2>The overall map</h2>
  <p class="muted">
    Every site, every path, every life-journey across the eight volumes —
    rendered as a captain's wall map pinned to dark oak.
  </p>
  <div class="maps-feature">
    <img src="/img/series_map_overall_photo.png" alt="Overall series map artifact" loading="lazy" />
    <div class="caption">The overall map — 1700 BCE through 2029 CE.</div>
  </div>

  <hr class="ornament" />

  <h2>The series timeline</h2>
  <p class="muted">
    Master chronological timeline, rendered as an aged refectory-table scroll.
  </p>
  <div class="maps-feature">
    <img src="/img/series_timeline_photo.png" alt="Series timeline artifact" loading="lazy" />
    <div class="caption">From the 1700 BCE asker's hill to the 2029 closing day.</div>
  </div>

  <hr class="ornament" />

  <h2>Per-book maps</h2>
  <p class="muted">
    One artifact per volume, in reading order. Each is the map the
    keepers of that volume might have laid open on their desk.
  </p>

  <div class="maps-grid">
    {books.map((book) => (
      <a class="map-card" href={`/spiral-continuum/books/${book.data.id}`}>
        <img src={`/img/series_map_book${book.data.id}_photo.png`} alt={`Map artifact for ${book.data.title}`} loading="lazy" />
        <h3>Book {book.data.id} &mdash; {book.data.title}</h3>
        <p class="caption" set:html={mapCaptions[book.data.id]} />
      </a>
    ))}
  </div>

  </section>

  <hr class="ornament" />

  <section id="island-of-bones" class="maps-section">
    <header class="maps-section-head">
      <h2><span class="glyph">⌒</span> Island of Bones</h2>
      <p class="muted">
        The Island of Bones map suite is in production. The series's hero
        geography spans the U.S. and British Virgin Islands, the Florida
        Keys (Cayo Hueso), the Mississippi corridor, and the southern
        terminus at Natal, Brazil. The Codec is hemisphere-spanning; the
        maps will be too.
      </p>
      <p class="muted">
        Until the IoB supplement ships, see the
        {' '}<a href="/island-of-bones">series page</a> for setting
        breakdowns per volume.
      </p>
    </header>

    <div class="maps-placeholder">
      <p>The IoB map suite will land alongside the first publishable Book 1 wrap.</p>
    </div>
  </section>

  <hr class="ornament" />

  <p class="muted">
    {supplement.why_separate}
  </p>
</Layout>
